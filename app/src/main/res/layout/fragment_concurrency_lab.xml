<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Выполнение в потоках" android:textSize="18sp" android:textStyle="bold"
                    android:layout_marginBottom="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btnStartThreadTask" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Запустить" android:layout_marginEnd="8dp" />
                    <Button android:id="@+id/btnCancelThreadTask" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Отменить" android:enabled="false" />
                </LinearLayout>
                <TextView android:id="@+id/tvThreadProgress" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Прогресс: 0%"
                    android:layout_marginTop="8dp" android:textSize="14sp" />
                <TextView android:id="@+id/tvThreadResult" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Результат: ожидание"
                    android:layout_marginTop="4dp" android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Последовательное выполнение (потоки)" android:textSize="18sp"
                    android:textStyle="bold" android:layout_marginBottom="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btnStartSequentialThreads" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Запустить" android:layout_marginEnd="8dp" />
                    <Button android:id="@+id/btnCancelSequentialThreads" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Отменить" android:enabled="false" />
                </LinearLayout>
                <TextView android:id="@+id/tvSequentialResult" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Результат: ожидание"
                    android:layout_marginTop="8dp" android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Корутины (GlobalScope + Dispatchers.Default)" android:textSize="18sp"
                    android:textStyle="bold" android:layout_marginBottom="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btnStartGlobalScopeTask" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Запустить" android:layout_marginEnd="8dp" />
                    <Button android:id="@+id/btnCancelGlobalScopeTask" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Отменить" android:enabled="false" />
                </LinearLayout>
                <TextView android:id="@+id/tvGlobalScopeProgress" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Прогресс: 0%"
                    android:layout_marginTop="8dp" android:textSize="14sp" />
                <TextView android:id="@+id/tvGlobalScopeResult" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Результат: ожидание"
                    android:layout_marginTop="4dp" android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Корутины (viewModelScope + Dispatchers.IO)" android:textSize="18sp"
                    android:textStyle="bold" android:layout_marginBottom="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btnStartViewModelScopeTask" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Запустить" android:layout_marginEnd="8dp" />
                    <Button android:id="@+id/btnCancelViewModelScopeTask" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Отменить" android:enabled="false" />
                </LinearLayout>
                <TextView android:id="@+id/tvViewModelScopeProgress" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Прогресс: 0%"
                    android:layout_marginTop="8dp" android:textSize="14sp" />
                <TextView android:id="@+id/tvViewModelScopeResult" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Результат: ожидание"
                    android:layout_marginTop="4dp" android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
